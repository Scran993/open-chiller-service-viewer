    { "group": "Alarms", "name": "General alarm", "register": 20481, "bit": 8, "function": "03", "scale": 1, "unit": "", "notes": "From ADU 20481.08" },
    { "group": "Alarms", "name": "Phase loss alarm", "register": 20481, "bit": 9, "function": "03", "scale": 1, "unit": "", "notes": "From ADU 20481.09" },
    { "group": "Pressure alarms", "name": "General high pressure alarm", "register": 20482, "bit": 8, "function": "03", "scale": 1, "unit": "", "notes": "From ADU 20482.08" },
    { "group": "Pressure alarms", "name": "Circuit 1 high pressure alarm", "register": 20482, "bit": 9, "function": "03", "scale": 1, "unit": "", "notes": "From ADU 20482.09" },
    { "group": "Pressure alarms", "name": "General low pressure alarm", "register": 20482, "bit": 14, "function": "03", "scale": 1, "unit": "", "notes": "From ADU 20482.14" },
    { "group": "Pressure alarms", "name": "Circuit 1 low pressure alarm", "register": 20482, "bit": 15, "function": "03", "scale": 1, "unit": "", "notes": "From ADU 20482.15" }
  ]

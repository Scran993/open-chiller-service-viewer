    { "group": "Overview", "name": "Compressor status", "register": 16389, "function": "03", "scale": 1, "unit": "", "notes": "0=ALL OFF, enum" },
    { "group": "Overview", "name": "Control probe", "register": 16480, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Main control temperature" },
    { "group": "Overview", "name": "Actual setpoint", "register": 16481, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Active setpoint" },
    { "group": "Overview", "name": "Requested power", "register": 16484, "function": "03", "scale": 0.1, "unit": "%", "notes": "" },
    { "group": "Overview", "name": "Actual power", "register": 16485, "function": "03", "scale": 0.1, "unit": "%", "notes": "" },
    { "group": "Water temperatures", "name": "Inlet water evaporator temperature", "register": 21762, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Physical AI from scan" },
    { "group": "Water temperatures", "name": "Outlet water evaporator temperature 1", "register": 21763, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "32767 means unavailable/fault" },
    { "group": "Pressures", "name": "Discharge pressure circuit 1", "register": 21766, "function": "03", "scale": 0.1, "unit": "barg", "invalidRaw": [32767, 32768, 65535], "notes": "32767 means unavailable/fault" },
    { "group": "Pressures", "name": "EEV1 Pe evaporating pressure", "register": 20743, "function": "03", "scale": 0.01, "unit": "bar", "invalidRaw": [32767, 32768, 65535], "notes": "Matches EKE screen Pe" },
    { "group": "Pressures", "name": "EEV2 Pe evaporating pressure", "register": 20843, "function": "03", "scale": 0.01, "unit": "bar", "invalidRaw": [32767, 32768, 65535], "notes": "Matches EKE screen Pe" },
    { "group": "Expansion valve 1", "name": "Valve opening degree", "register": 20738, "function": "03", "scale": 0.1, "unit": "%", "notes": "" },
    { "group": "Expansion valve 1", "name": "S2 temperature", "register": 20740, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Added from EKE display comparison" },
    { "group": "Expansion valve 1", "name": "Actual superheat SH", "register": 20741, "function": "03", "scale": 0.1, "unit": "K", "invalidRaw": [32767, 32768, 65535], "notes": "Matches EKE screen SH" },
    { "group": "Expansion valve 1", "name": "Superheat reference SR", "register": 20742, "function": "03", "scale": 0.1, "unit": "K", "invalidRaw": [32767, 32768, 65535], "notes": "Matches EKE screen SR" },
    { "group": "Expansion valve 1", "name": "Evaporating temperature", "register": 20744, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Temperature derived/displayed beside Pe" },
    { "group": "Expansion valve 1", "name": "S4 temperature", "register": 20745, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "EKE screen S4; often unavailable" },
    { "group": "Expansion valve 1", "name": "Operating state", "register": 20749, "function": "03", "scale": 1, "unit": "", "notes": "EKE OP.ST." },
    { "group": "Expansion valve 2", "name": "Valve opening degree", "register": 20838, "function": "03", "scale": 0.1, "unit": "%", "notes": "" },
    { "group": "Expansion valve 2", "name": "S2 temperature", "register": 20840, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Added from EKE display comparison" },
    { "group": "Expansion valve 2", "name": "Actual superheat SH", "register": 20841, "function": "03", "scale": 0.1, "unit": "K", "invalidRaw": [32767, 32768, 65535], "notes": "Matches EKE screen SH" },
    { "group": "Expansion valve 2", "name": "Superheat reference SR", "register": 20842, "function": "03", "scale": 0.1, "unit": "K", "invalidRaw": [32767, 32768, 65535], "notes": "Matches EKE screen SR" },
    { "group": "Expansion valve 2", "name": "Evaporating temperature", "register": 20844, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "Temperature derived/displayed beside Pe" },
    { "group": "Expansion valve 2", "name": "S4 temperature", "register": 20845, "function": "03", "scale": 0.1, "unit": "C", "invalidRaw": [32767, 32768, 65535], "notes": "EKE screen S4; often unavailable" },

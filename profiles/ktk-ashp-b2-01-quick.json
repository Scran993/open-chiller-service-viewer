{
  "name": "KTK ASHP/B2/01 field view",
  "source": "Short test profile from scanned.pdf - KTK Multipower_v9.34.00 21-221296-ID40.mcxs",
  "connection": {
    "protocol": "Modbus RTU",
    "slaveId": 40,
    "baudRate": 19200,
    "serial": "8N1",
    "notes": "Proven site field view. Includes live overview, temperatures, EEV evaporator pressure, and key pressure alarms."
  },
  "registers": [
